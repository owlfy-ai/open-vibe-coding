{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "qidea",
  "compatibility_date": "2026-07-01",
  "workers_dev": true,
  "routes": [
    {
      "pattern": "qidea.ai/*",
      "zone_name": "qidea.ai"
    },
    {
      "pattern": "*.qidea.ai/*",
      "zone_name": "qidea.ai"
    }
  ],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
